# === LLM 配置 ===
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://api.deepseek.com/v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# === 嵌入模型 ===
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === 向量搜索 ===
VECTOR_SEARCH_LIMIT=5

# === 文本分块 ===
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# === 运行配置 ===
DEBUG=true
MAX_HISTORY_MESSAGES=20
